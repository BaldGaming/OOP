<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<HBox spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mines.MinesController">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <VBox alignment="CENTER" prefWidth="120.0" spacing="10.0">
         <children>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#resetGame" text="Reset" />
            <HBox alignment="CENTER_LEFT" spacing="5.0">
               <children>
                  <Label minWidth="-Infinity" text="width" />
                  <TextField fx:id="widthInput" text="10" />
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="5.0">
               <children>
                  <Label minWidth="-Infinity" text="height" />
                  <TextField fx:id="heightInput" text="10" />
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="5.0">
               <children>
                  <Label minWidth="-Infinity" text="mines" />
                  <TextField fx:id="minesInput" text="10" />
               </children>
            </HBox>
         </children>
      </VBox>
      <StackPane fx:id="gridContainer" style="-fx-background-color: #f0f0f0; -fx-border-color: #ccc; -fx-border-width: 1px;">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </StackPane>
   </children>
</HBox>